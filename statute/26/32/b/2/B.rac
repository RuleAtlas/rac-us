# 26 USC 32(b)(2)(B) - Joint returns

"""
(B) Joint returns
In the case of a joint return filed by an eligible individual and such
individual's spouse, the phaseout amount determined under subparagraph (A)
shall be increased by $5,000.
"""

joint_return_phaseout_increase:
  description: "Increase in phaseout amount for joint returns per 26 USC 32(b)(2)(B)"
  unit: USD
  from 2002-01-01: 5000
