taxpayer_meets_eitc_age:
  - name: "Age 30 - meets requirement"
    period: 2024-01
    inputs:
        taxpayer_age: 30
    expect: 1
  - name: "Age 24 - too young"
    period: 2024-01
    inputs:
        taxpayer_age: 24
    expect: 0
  - name: "Age 65 - too old"
    period: 2024-01
    inputs:
        taxpayer_age: 65
    expect: 0
  - name: "Age 25 - meets minimum"
    period: 2024-01
    inputs:
        taxpayer_age: 25
    expect: 1
  - name: "Age 64 - meets maximum"
    period: 2024-01
    inputs:
        taxpayer_age: 64
    expect: 1

eitc_meets_age_requirement:
  - name: "Single taxpayer age 30"
    period: 2024-01
    inputs:
        taxpayer_meets_eitc_age: 1
        spouse_meets_eitc_age: 0
        is_married_eitc: 0
    expect: 1
  - name: "Single taxpayer too young"
    period: 2024-01
    inputs:
        taxpayer_meets_eitc_age: 0
        spouse_meets_eitc_age: 0
        is_married_eitc: 0
    expect: 0
  - name: "Married - taxpayer fails, spouse passes"
    period: 2024-01
    inputs:
        taxpayer_meets_eitc_age: 0
        spouse_meets_eitc_age: 1
        is_married_eitc: 1
    expect: 1
  - name: "Married - both fail"
    period: 2024-01
    inputs:
        taxpayer_meets_eitc_age: 0
        spouse_meets_eitc_age: 0
        is_married_eitc: 1
    expect: 0

eitc_meets_id_number_requirement:
  - name: "Single with TIN"
    period: 2024-01
    inputs:
        taxpayer_has_tin_on_return: 1
        is_married_eitc: 0
        spouse_has_tin_on_return: 0
    expect: 1
  - name: "Single missing TIN"
    period: 2024-01
    inputs:
        taxpayer_has_tin_on_return: 0
        is_married_eitc: 0
        spouse_has_tin_on_return: 0
    expect: 0
  - name: "Married both have TIN"
    period: 2024-01
    inputs:
        taxpayer_has_tin_on_return: 1
        is_married_eitc: 1
        spouse_has_tin_on_return: 1
    expect: 1
  - name: "Married spouse missing TIN"
    period: 2024-01
    inputs:
        taxpayer_has_tin_on_return: 1
        is_married_eitc: 1
        spouse_has_tin_on_return: 0
    expect: 0

eitc_nonresident_alien_eligible:
  - name: "Not a nonresident alien"
    period: 2024-01
    inputs:
        is_nonresident_alien: 0
        elected_resident_treatment_6013: 0
    expect: 1
  - name: "Nonresident alien without 6013 election"
    period: 2024-01
    inputs:
        is_nonresident_alien: 1
        elected_resident_treatment_6013: 0
    expect: 0
  - name: "Nonresident alien with 6013 election"
    period: 2024-01
    inputs:
        is_nonresident_alien: 1
        elected_resident_treatment_6013: 1
    expect: 1

is_eitc_eligible_individual:
  - name: "Individual with qualifying child"
    period: 2024-01
    inputs:
        has_eitc_qualifying_child: 1
        is_qualifying_child_of_another: 0
        claims_section_911_benefits: 0
        eitc_nonresident_alien_eligible: 1
        eitc_meets_id_number_requirement: 1
        principal_abode_in_us_over_half_year: 0
        eitc_meets_age_requirement: 0
        is_dependent_of_another: 0
    expect: 1
  - name: "Childless individual meeting all requirements"
    period: 2024-01
    inputs:
        has_eitc_qualifying_child: 0
        is_qualifying_child_of_another: 0
        claims_section_911_benefits: 0
        eitc_nonresident_alien_eligible: 1
        eitc_meets_id_number_requirement: 1
        principal_abode_in_us_over_half_year: 1
        eitc_meets_age_requirement: 1
        is_dependent_of_another: 0
    expect: 1
  - name: "Childless - abode not in US"
    period: 2024-01
    inputs:
        has_eitc_qualifying_child: 0
        is_qualifying_child_of_another: 0
        claims_section_911_benefits: 0
        eitc_nonresident_alien_eligible: 1
        eitc_meets_id_number_requirement: 1
        principal_abode_in_us_over_half_year: 0
        eitc_meets_age_requirement: 1
        is_dependent_of_another: 0
    expect: 0
  - name: "Is qualifying child of another"
    period: 2024-01
    inputs:
        has_eitc_qualifying_child: 1
        is_qualifying_child_of_another: 1
        claims_section_911_benefits: 0
        eitc_nonresident_alien_eligible: 1
        eitc_meets_id_number_requirement: 1
        principal_abode_in_us_over_half_year: 1
        eitc_meets_age_requirement: 1
        is_dependent_of_another: 0
    expect: 0
  - name: "Claims section 911 benefits"
    period: 2024-01
    inputs:
        has_eitc_qualifying_child: 1
        is_qualifying_child_of_another: 0
        claims_section_911_benefits: 1
        eitc_nonresident_alien_eligible: 1
        eitc_meets_id_number_requirement: 1
        principal_abode_in_us_over_half_year: 1
        eitc_meets_age_requirement: 1
        is_dependent_of_another: 0
    expect: 0

eitc_earned_income:
  - name: "Wages only"
    period: 2024-01
    inputs:
        wages_salaries_tips: 30000
        net_earnings_self_employment: 0
        pension_annuity_income: 0
        income_section_871a: 0
        penal_institution_wages: 0
        subsidized_work_activity_income: 0
    expect: 30000
  - name: "Combined wages and self-employment"
    period: 2024-01
    inputs:
        wages_salaries_tips: 25000
        net_earnings_self_employment: 15000
        pension_annuity_income: 0
        income_section_871a: 0
        penal_institution_wages: 0
        subsidized_work_activity_income: 0
    expect: 40000
  - name: "With exclusions"
    period: 2024-01
    inputs:
        wages_salaries_tips: 30000
        net_earnings_self_employment: 10000
        pension_annuity_income: 0
        income_section_871a: 0
        penal_institution_wages: 5000
        subsidized_work_activity_income: 3000
    expect: 32000
  - name: "Exclusions exceed income - floor at zero"
    period: 2024-01
    inputs:
        wages_salaries_tips: 1000
        net_earnings_self_employment: 0
        pension_annuity_income: 0
        income_section_871a: 0
        penal_institution_wages: 0
        subsidized_work_activity_income: 2000
    expect: 0
