# 26 USC 32(j)(1)(B)(iii) - Subsection (i)(1) base year

status: encoded

"""
(iii) in the case of the $10,000 amount in subsection (i)(1),
"calendar year 2020" for "calendar year 2016".
"""

i_1_base_year:
    description: "Base calendar year substituted for 'calendar year 2016' when computing cost-of-living adjustment for the $10,000 disqualified income threshold in 26 USC 32(i)(1)"
    unit: year
    from 2022-01-01: 2020
