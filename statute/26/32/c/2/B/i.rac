# 26 USC 32(c)(2)(B)(i) - Community property

"""
(i) the earned income of an individual shall be computed without regard to any
community property laws,
"""

status: encoded

disregard_community_property_laws:
  entity: TaxUnit
  period: Year
  dtype: Boolean
  label: "Disregard Community Property Laws"
  description: "Earned income for EITC purposes is computed without regard to any community property laws per 26 USC 32(c)(2)(B)(i)"
  from 1975-01-01:
    return 1
